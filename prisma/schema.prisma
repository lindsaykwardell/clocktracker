generator client {
  provider = "prisma-client"
  output   = "../server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model FeatureFlag {
  id                     Int            @id @default(autoincrement())
  name                   String
  description            String
  active                 Boolean        @default(false)
  active_for             UserSettings[]
  enabled_for_supporters Boolean        @default(false)
  rollout_percentage     Int?
  effective_date         DateTime?
  created_at             DateTime       @default(now()) @db.Timestamptz(6)
}

model Game {
  id                          String         @id @default(uuid())
  bgg_id                      Int?           @unique
  ls_game_id                  Int?           @unique
  ls_game                     LSGame?        @relation(fields: [ls_game_id], references: [id])
  user_id                     String
  created_at                  DateTime?      @default(now()) @db.Timestamptz(6)
  date                        DateTime       @default(now()) @db.Date
  script                      String
  script_id                   Int?
  location_type               LocationType   @default(ONLINE)
  location                    String
  community_name              String         @default("")
  community                   Community?     @relation(fields: [community_id], references: [id])
  community_id                Int?
  player_count                Int?
  traveler_count              Int?
  player_characters           Character[]
  win_v2                      WinStatus_V2   @default(NOT_RECORDED)
  end_trigger                 GameEndTrigger @default(NOT_RECORDED)
  end_trigger_type            GameEndTriggerType?
  end_trigger_cause           GameEndTriggerCause?
  end_trigger_role            Role?          @relation("GameEndTriggerRole", fields: [end_trigger_role_id], references: [id])
  end_trigger_role_id         String?
  end_trigger_subtype         String         @default("")
  end_trigger_note            String         @default("")
  end_trigger_participant_id String?
  end_trigger_participant_alignment Alignment?
  notes                       String
  image_urls                  String[]
  old_image_urls              String[]
  storyteller                 String?
  co_storytellers             String[]
  user                        UserSettings?  @relation(fields: [user_id], references: [user_id])
  associated_script           Script?        @relation(fields: [script_id], references: [id])
  grimoire                    Grimoire[]
  grimoire_id                 Int?           @unique
  is_storyteller              Boolean        @default(false)
  parent_game                 Game?          @relation("AssociatedGame", fields: [parent_game_id], references: [id])
  parent_game_id              String?
  child_games                 Game[]         @relation("AssociatedGame")
  ignore_for_stats            Boolean        @default(false)
  tags                        String[]
  waiting_for_confirmation    Boolean        @default(false)
  deleted                     Boolean        @default(false)
  deleted_date                DateTime?
  privacy                     PrivacySetting @default(PUBLIC)
  demon_bluffs                DemonBluff[]
  fabled                      Fabled[]
  grimoire_events             GrimoireEvent[]
  favorite                    FavoriteGame?
  favorite_id                 Int?           @unique
  grimoire_snapshots          GrimoireSnapshot[]

  @@index([user_id])
}

model ImportedGame {
  id      String @id @default(uuid())
  payload String
}

model FavoriteGame {
  id         Int          @id @default(autoincrement())
  user       UserSettings @relation(fields: [user_id], references: [user_id])
  user_id    String
  game       Game         @relation(fields: [game_id], references: [id])
  game_id    String       @unique
  created_at DateTime     @default(now()) @db.Timestamptz(6)

  @@unique([user_id, game_id])
}

enum WinStatus_V2 {
  GOOD_WINS
  EVIL_WINS
  NOT_RECORDED
}

enum GameEndTrigger {
  NOT_RECORDED
  TWO_PLAYERS_LEFT_ALIVE
  NO_LIVING_DEMON
  ADDITIONAL_WIN_CONDITION
  GAME_ENDED_EARLY
  OTHER
}

enum GameEndTriggerType {
  DEATH
  EXECUTION
  CHARACTER_CHANGE
  EXTRA_WIN_CONDITION
  OTHER
}

enum GameEndTriggerCause {
  ABILITY
  NOMINATION
  FAILED_ABILITY
}

enum GrimoireEventCause {
  ABILITY
  NOMINATION
}

enum GrimoireEventType {
  NOT_RECORDED
  DEATH
  EXECUTION
  REVIVE
  ROLE_CHANGE
  SEAT_CHANGE
  ALIGNMENT_CHANGE
  MAD
  DRUNK
  POISONED
  OTHER
}

enum GrimoirePageType {
  NONE
  NIGHT
  DAY
}

model GrimoireEvent {
  id                Int              @id @default(autoincrement())
  game              Game             @relation(fields: [game_id], references: [id])
  game_id           String
  grimoire_page     Int
  participant_id    String           @default("")
  event_type        GrimoireEventType @default(NOT_RECORDED)
  status_source     String?
  cause             GrimoireEventCause?
  by_participant_id String?
  player_name       String           @default("")
  role_id           String?
  role              Role?            @relation(fields: [role_id], references: [id])
  by_role_id        String?
  by_role           Role?            @relation("GrimoireEventByRole", fields: [by_role_id], references: [id])
  old_role_id       String?
  new_role_id       String?
  old_alignment     Alignment?
  new_alignment     Alignment?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
}

model Grimoire {
  id         Int                 @id @default(autoincrement())
  created_at DateTime            @default(now()) @db.Timestamptz(6)
  title      String   @default("")
  page_type  GrimoirePageType @default(NONE)
  tokens     Token[]
  game       Game[]
}

model GrimoireSnapshot {
  id           Int      @id @default(autoincrement())
  game_id      String
  game         Game     @relation(fields: [game_id], references: [id])
  snapshot     Json
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([game_id])
}

model Token {
  id                      Int             @id @default(autoincrement())
  grimoire_participant_id String?
  role                    Role?           @relation(fields: [role_id], references: [id])
  role_id                 String?
  related_role            Role?           @relation("RelatedToken", fields: [related_role_id], references: [id])
  related_role_id         String?
  alignment               Alignment
  is_dead                 Boolean         @default(false)
  used_ghost_vote         Boolean         @default(false)
  order                   Int
  created_at              DateTime        @default(now()) @db.Timestamptz(6)
  grimoire                Grimoire?       @relation(fields: [grimoire_id], references: [id])
  grimoire_id             Int?
  player_name             String          @default("")
  player                  UserSettings?   @relation(fields: [player_id], references: [user_id])
  player_id               String?
  reminders               ReminderToken[]
}

model ReminderToken {
  id         Int      @id @default(autoincrement())
  reminder   String   @default("")
  type       ReminderType @default(CUSTOM)
  token_url  String   @default("")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  token      Token?   @relation(fields: [token_id], references: [id])
  token_id   Int?
}

model Character {
  id              Int       @id @default(autoincrement())
  name            String
  role            Role?     @relation(fields: [role_id], references: [id])
  related         String?
  alignment       Alignment
  game            Game?     @relation(fields: [game_id], references: [id])
  game_id         String?
  role_id         String?
  related_role_id String?
  related_role    Role?     @relation("RelatedRole", fields: [related_role_id], references: [id])
}

model DemonBluff {
  id      Int     @id @default(autoincrement())
  name    String
  role    Role?   @relation(fields: [role_id], references: [id])
  related String?
  game    Game?   @relation(fields: [game_id], references: [id])
  game_id String?
  role_id String?
}

model Fabled {
  id      Int     @id @default(autoincrement())
  name    String
  role    Role?   @relation(fields: [role_id], references: [id])
  related String?
  game    Game?   @relation(fields: [game_id], references: [id])
  game_id String?
  role_id String?
}

model Script {
  id               Int           @id @default(autoincrement())
  script_id        String        @default(uuid()) // This is EITHER the botcscripts.com ID, or a custom script ID
  is_custom_script Boolean       @default(false)
  logo             String?
  website          String?
  name             String
  version          String
  author           String
  type             String
  json_url         String
  pdf_url          String
  description      String        @default("")
  background       String?
  json             String?
  user             UserSettings? @relation(fields: [user_id], references: [user_id])
  user_id          String?
  roles            Role[]
  games            Game[]
  events           Event[]
  ls_game          LSGame?

  @@unique([script_id, version])
}

model Role {
  id                   String         @id
  name                 String
  initial_alignment    Alignment
  ability              String         @default("")
  token_url            String
  alternate_token_urls String[]
  type                 RoleType
  custom_role          Boolean        @default(false)
  scripts              Script[]
  related_character    Character[]    @relation("RelatedRole")
  character            Character[]
  tokens               Token[]
  related_tokens       Token[]        @relation("RelatedToken")
  demon_bluffs         DemonBluff[]
  fabled               Fabled[]
  end_trigger_games    Game[]         @relation("GameEndTriggerRole")
  grimoire_events      GrimoireEvent[]
  grimoire_by_events   GrimoireEvent[]   @relation("GrimoireEventByRole")
  role_stat_cards      RoleStatCard[]
  reminders            RoleReminder[]
  ls_campaigns         LSCampaign[]
  ls_games             LSGame[]       @relation("Games")
  ls_game_deaths       LSGame[]       @relation("Deaths")
  ls_game_retires      LSGame[]       @relation("Retire")
}

model RoleReminder {
  id       Int    @id @default(autoincrement())
  reminder String
  type     ReminderType @default(OFFICIAL)
  role_id  String
  role     Role   @relation(fields: [role_id], references: [id])

  @@unique([role_id, reminder])
}

enum ReminderType {
  OFFICIAL
  TRACKING
  IMPORTED
  LEGACY
  CUSTOM
}

enum Alignment {
  GOOD
  EVIL
  NEUTRAL
}

enum RoleType {
  TOWNSFOLK
  OUTSIDER
  MINION
  DEMON
  TRAVELER
  FABLED
  LORIC
}

enum LocationType {
  ONLINE
  IN_PERSON
}

model UserSettings {
  user_id                 String                  @id
  discord_id              String?                 @unique
  username                String                  @unique
  display_name            String
  finished_welcome        Boolean                 @default(false)
  avatar                  String?
  old_avatar              String?
  email                   String                  @unique @default("your@address.here")
  pronouns                String?
  bio                     String                  @default("")
  location                String?
  city_id                 String?
  city                    City?                   @relation(fields: [city_id], references: [id])
  is_admin                Boolean                 @default(false)
  privacy                 PrivacySetting          @default(PUBLIC)
  created_at              DateTime?               @default(now()) @db.Timestamptz(6)
  games                   Game[]
  friend_requests         FriendRequest[]         @relation("Receiver")
  sent_friend_requests    FriendRequest[]         @relation("Sender")
  friends                 Friend[]                @relation("Friend")
  friend_of               Friend[]                @relation("FriendOf")
  token                   Token[]
  charts                  Chart[]
  role_stat_cards         RoleStatCard[]
  bgg_username            String?
  bgg_cookies             String[]
  enable_bgstats          Boolean                 @default(false)
  opt_into_testing        Boolean                 @default(false)
  disable_tutorials       Boolean                 @default(false)
  communities             Community[]             @relation("CommunityMember")
  community_admin         Community[]             @relation("CommunityAdmin")
  community_banned        Community[]             @relation("CommunityBanned")
  community_join_requests Community[]             @relation("CommunityJoinRequest")
  community_posts         CommunityPost[]
  events                  EventAttendee[]
  FeatureFlag             FeatureFlag[]
  waitlisted_events       EventWaitlistAttendee[]
  payments                KoFiPayment[]
  uploaded_scripts        Script[]
  dids                    Did[]
  favorites               FavoriteGame[]
  created_events          Event[]
  year_reviews            YearInReview[]
  forum_group_memberships UserGroupMembership[]
  forum_threads           ForumThread[]
  forum_posts             ForumPost[]
  forum_bans              ForumBan[]          @relation("BannedUser")
  forum_bans_issued       ForumBan[]          @relation("BannedByUser")
  forum_reactions         ForumPostReaction[]
  forum_reports           ForumPostReport[]   @relation("ReportedBy")
  forum_reports_resolved  ForumPostReport[]   @relation("ResolvedBy")
  forum_edits             ForumPostEdit[]
  forum_mod_logs          ForumModLog[]
  forum_subscriptions     ForumThreadSubscription[]
  forum_category_subscriptions ForumCategorySubscription[]
  forum_reads             ForumThreadRead[]
  forum_first_visit_at    DateTime?               @db.Timestamptz(6)
  push_notifications_enabled Boolean              @default(false)
  push_subscriptions      PushSubscription[]
  fcm_tokens              FcmToken[]
}

model Did {
  id         Int          @id @default(autoincrement())
  user       UserSettings @relation(fields: [user_id], references: [user_id])
  user_id    String
  did        String
  created_at DateTime     @default(now()) @db.Timestamptz(6)

  @@unique([user_id, did])
}

model KoFiPayment {
  id                      Int           @id @default(autoincrement())
  email                   String
  is_subscription_payment Boolean       @default(false)
  timestamp               DateTime
  expires_at              DateTime
  user                    UserSettings? @relation(fields: [user_id], references: [user_id])
  user_id                 String?
}

enum PrivacySetting {
  PUBLIC
  PRIVATE
  FRIENDS_ONLY
  PERSONAL
}

model YearInReview {
  id      String       @id @default(uuid())
  year    Int
  user    UserSettings @relation(fields: [user_id], references: [user_id])
  user_id String

  @@unique([year, user_id])
}

model FriendRequest {
  id           Int          @id @default(autoincrement())
  user         UserSettings @relation("Receiver", fields: [user_id], references: [user_id])
  from_user    UserSettings @relation("Sender", fields: [from_user_id], references: [user_id])
  user_id      String
  from_user_id String
  accepted     Boolean      @default(false)
  created_at   DateTime?    @default(now()) @db.Timestamptz(6)

  @@unique([user_id, from_user_id])
}

model Friend {
  id         Int          @id @default(autoincrement())
  user       UserSettings @relation("FriendOf", fields: [user_id], references: [user_id])
  friend     UserSettings @relation("Friend", fields: [friend_id], references: [user_id])
  user_id    String
  friend_id  String
  created_at DateTime?    @default(now()) @db.Timestamptz(6)

  @@index([user_id])
}

model Chart {
  id               Int          @id @default(autoincrement())
  user             UserSettings @relation(fields: [user_id], references: [user_id])
  user_id          String
  title            String
  type             ChartType
  data             DataField
  pivot            DataField?
  include_tags     String[]
  exclude_tags     String[]
  width            Int
  height           Int
  storyteller_only Boolean      @default(false)
}

model RoleStatCard {
  id               Int          @id @default(autoincrement())
  user             UserSettings @relation(fields: [user_id], references: [user_id])
  user_id          String
  role             Role?        @relation(fields: [role_id], references: [id])
  role_id          String?
  source           String
  metric_key       String
  storyteller_only Boolean      @default(false)
  created_at       DateTime     @default(now()) @db.Timestamptz(6)
}

enum ChartType {
  BAR
  PIE
  POLAR_AREA
  LIST
}

enum DataField {
  ROLE
  ALIGNMENT
  SCRIPT
  GAME_SIZE
  WIN
}

model Community {
  id                Int             @id @default(autoincrement())
  name              String
  slug              String          @unique
  description       String
  members           UserSettings[]  @relation("CommunityMember")
  admins            UserSettings[]  @relation("CommunityAdmin")
  banned_users      UserSettings[]  @relation("CommunityBanned")
  join_requests     UserSettings[]  @relation("CommunityJoinRequest")
  created_at        DateTime?       @default(now()) @db.Timestamptz(6)
  deleted           Boolean         @default(false)
  deleted_date      DateTime?
  posts             CommunityPost[]
  icon              String          @default("/img/default.png")
  old_icon          String?
  games             Game[]
  is_private        Boolean         @default(false)
  events            Event[]
  discord_server_id String?
  time_zone         String          @default("UTC")
  links             String[]
  location          String?
  city_id           String?
  city              City?           @relation(fields: [city_id], references: [id])
}

model CommunityPost {
  id           String          @id @default(uuid())
  community    Community       @relation(fields: [community_id], references: [id])
  community_id Int
  user         UserSettings    @relation(fields: [user_id], references: [user_id])
  user_id      String
  content      String
  created_at   DateTime        @default(now()) @db.Timestamptz(6)
  deleted      Boolean         @default(false)
  deleted_date DateTime?
  reply_to     CommunityPost?  @relation("Reply", fields: [reply_to_id], references: [id])
  reply_to_id  String?
  replies      CommunityPost[] @relation("Reply")
}

model Event {
  id                   String                  @id @default(uuid())
  created_at           DateTime                @default(now()) @db.Timestamptz(6)
  start                DateTime                @default(now()) @db.Timestamptz(6)
  end                  DateTime                @default(dbgenerated("(now() + '01:30:00'::interval)")) @db.Timestamptz(6)
  title                String
  description          String
  player_count         Int?
  location_type        LocationType            @default(ONLINE)
  location             String
  image                String?
  old_image            String?
  storytellers         String[]
  script               String                  @default("")
  script_id            Int?
  associated_script    Script?                 @relation(fields: [script_id], references: [id])
  game_link            String?
  short_link           String?                 @unique
  registered_players   EventAttendee[]
  community            Community?              @relation(fields: [community_id], references: [id])
  community_id         Int?
  created_by           UserSettings?           @relation(fields: [created_by_id], references: [user_id])
  created_by_id        String?
  who_can_register     WhoCanRegister          @default(COMMUNITY_MEMBERS)
  waitlists            EventWaitlist[]
  discord_posts        EventDiscordPost[]
  restricted_attendees EventRegistrationSpam[]
  has_pinged_discord   Boolean                 @default(false)
}

model EventDiscordPost {
  event      Event    @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_id   String
  message_id String
  channel_id String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@id([channel_id, message_id])
}

enum WhoCanRegister {
  ANYONE
  PRIVATE
  COMMUNITY_MEMBERS
}

model EventAttendee {
  id              Int           @id @default(autoincrement())
  event           Event         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_id        String
  name            String
  user            UserSettings? @relation(fields: [user_id], references: [user_id])
  user_id         String?
  discord_user_id String?
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  ip_address      String?
}

model EventWaitlist {
  id         Int                     @id @default(autoincrement())
  event      Event                   @relation(fields: [event_id], references: [id], onDelete: Cascade)
  event_id   String
  name       String
  created_at DateTime                @default(now()) @db.Timestamptz(6)
  users      EventWaitlistAttendee[]
  default    Boolean                 @default(false)
}

model EventWaitlistAttendee {
  id              Int           @id @default(autoincrement())
  waitlist        EventWaitlist @relation(fields: [waitlist_id], references: [id], onDelete: Cascade)
  waitlist_id     Int
  name            String
  user            UserSettings? @relation(fields: [user_id], references: [user_id])
  user_id         String?
  discord_user_id String?
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  ip_address      String?
}

// Model for any IP address of an anonymous user who has registered for an event
// too many times.
model EventRegistrationSpam {
  id         Int      @id @default(autoincrement())
  ip_address String
  name       String
  event_id   String
  event      Event    @relation(fields: [event_id], references: [id])
  created_at DateTime @default(now()) @db.Timestamptz(6)
  is_banned  Boolean  @default(false)

  @@unique([ip_address, event_id])
}

model City {
  id          String         @id
  name        String
  latitude    Float
  longitude   Float
  users       UserSettings[]
  communities Community[]
}

model CronLock {
  task_id    String   @id
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

model AppUpdate {
  id          String   @id
  description String?
  status      String   @default("PENDING")
  cursor      String?
  stats       Json?
  error       String?
  started_at  DateTime? @db.Timestamptz(6)
  finished_at DateTime? @db.Timestamptz(6)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @updatedAt @db.Timestamptz(6)

  @@index([status])
}

model LSCampaign {
  id                    String   @id
  title                 String
  author                String
  end_condition         String?
  end_value             String   @default("")
  max_townsfolk         Int
  max_outsiders         Int
  max_minions           Int
  max_demons            Int
  script_growth_speed   String   @default("off")
  script_truncate_speed String   @default("off")
  like_surprises        Boolean  @default(false)
  reserved_characters   Role[]
  games                 LSGame[]
}

model LSGame {
  id             Int          @id
  game_number    Int
  characters     Role[]       @relation("Games")
  deaths         Role[]       @relation("Deaths")
  retire         Role[]       @relation("Retire")
  created        DateTime
  submitted      DateTime?
  win            WinStatus_V2 @default(NOT_RECORDED)
  notes          String       @default("")
  campaign       LSCampaign   @relation(fields: [ls_campaign_id], references: [id])
  ls_campaign_id String
  game           Game[]
  script         Script?      @relation(fields: [script_id], references: [id])
  script_id      Int?         @unique

  @@unique([id, game_number])
}

// ---- Forum ----

model UserGroup {
  id           String                @id @default(uuid())
  name         String                @unique
  permissions  String[]
  restrictions String[]              @default([])
  is_default   Boolean               @default(false)
  color        String?
  created_at   DateTime              @default(now()) @db.Timestamptz(6)
  members      UserGroupMembership[]
  categories   CategoryAccess[]
}

model UserGroupMembership {
  id          String       @id @default(uuid())
  user_id     String
  group_id    String
  assigned_at DateTime     @default(now()) @db.Timestamptz(6)
  user        UserSettings @relation(fields: [user_id], references: [user_id])
  group       UserGroup    @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([user_id, group_id])
}

model ForumCategoryGroup {
  id         String          @id @default(uuid())
  name       String
  sort_order Int             @default(0)
  created_at DateTime        @default(now()) @db.Timestamptz(6)
  categories ForumCategory[]
}

model ForumCategory {
  id          String              @id @default(uuid())
  name        String
  slug        String              @unique
  description String?
  sort_order  Int                 @default(0)
  is_private       Boolean             @default(false)
  mod_posting_only Boolean             @default(false)
  is_announcement  Boolean             @default(false)
  created_at       DateTime            @default(now()) @db.Timestamptz(6)
  group_id         String?
  group            ForumCategoryGroup? @relation(fields: [group_id], references: [id])
  threads          ForumThread[]
  access           CategoryAccess[]
  bans             ForumBan[]
  subscriptions    ForumCategorySubscription[]
}

model CategoryAccess {
  id          String        @id @default(uuid())
  category_id String
  group_id    String
  can_view    Boolean       @default(true)
  can_post    Boolean       @default(true)
  category    ForumCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  group       UserGroup     @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([category_id, group_id])
}

model ForumThread {
  id           String        @id @default(uuid())
  title        String
  category_id  String
  author_id    String
  is_pinned    Boolean       @default(false)
  is_locked    Boolean       @default(false)
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  last_post_at DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime?     @db.Timestamptz(6)
  github_issue_url String?
  category      ForumCategory           @relation(fields: [category_id], references: [id])
  author        UserSettings            @relation(fields: [author_id], references: [user_id])
  posts         ForumPost[]
  subscriptions ForumThreadSubscription[]
  reads         ForumThreadRead[]

  @@index([category_id, deleted_at])
  @@index([last_post_at])
}

model ForumPost {
  id         String              @id @default(uuid())
  body       String
  thread_id  String
  author_id  String
  created_at DateTime            @default(now()) @db.Timestamptz(6)
  edited_at  DateTime?           @db.Timestamptz(6)
  deleted_at DateTime?           @db.Timestamptz(6)
  thread     ForumThread         @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  author     UserSettings        @relation(fields: [author_id], references: [user_id])
  reactions  ForumPostReaction[]
  reports    ForumPostReport[]
  edits      ForumPostEdit[]

  @@index([thread_id, deleted_at])
}

model ForumCategorySubscription {
  id          String        @id @default(uuid())
  category_id String
  user_id     String
  created_at  DateTime      @default(now()) @db.Timestamptz(6)
  category    ForumCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  user        UserSettings  @relation(fields: [user_id], references: [user_id])

  @@unique([category_id, user_id])
  @@index([user_id])
}

model ForumThreadSubscription {
  id            String       @id @default(uuid())
  thread_id     String
  user_id       String
  last_read_at  DateTime     @default(now()) @db.Timestamptz(6)
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  thread        ForumThread  @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  user          UserSettings @relation(fields: [user_id], references: [user_id])

  @@unique([thread_id, user_id])
  @@index([user_id])
}

model ForumThreadRead {
  id            String       @id @default(uuid())
  thread_id     String
  user_id       String
  last_read_at  DateTime     @default(now()) @db.Timestamptz(6)
  thread        ForumThread  @relation(fields: [thread_id], references: [id], onDelete: Cascade)
  user          UserSettings @relation(fields: [user_id], references: [user_id])

  @@unique([thread_id, user_id])
  @@index([user_id])
}

model ForumPostEdit {
  id            String       @id @default(uuid())
  post_id       String
  previous_body String
  edited_by     String
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  post          ForumPost    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  editor        UserSettings @relation(fields: [edited_by], references: [user_id])

  @@index([post_id])
}

model ForumPostReaction {
  id         String       @id @default(uuid())
  post_id    String
  user_id    String
  emoji      String
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  post       ForumPost    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user       UserSettings @relation(fields: [user_id], references: [user_id])

  @@unique([post_id, user_id, emoji])
  @@index([post_id])
}

model ForumPostReport {
  id          String       @id @default(uuid())
  post_id     String
  reporter_id String
  reason      String
  resolved    Boolean      @default(false)
  resolved_by String?
  resolved_at DateTime?    @db.Timestamptz(6)
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  post        ForumPost    @relation(fields: [post_id], references: [id], onDelete: Cascade)
  reporter    UserSettings @relation("ReportedBy", fields: [reporter_id], references: [user_id])
  resolver    UserSettings? @relation("ResolvedBy", fields: [resolved_by], references: [user_id])

  @@index([post_id])
  @@index([resolved])
}

model ForumModLog {
  id          String       @id @default(uuid())
  action      String
  actor_id    String
  target_type String
  target_id   String
  details     String?
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  actor       UserSettings @relation(fields: [actor_id], references: [user_id])

  @@index([created_at])
}

model PushSubscription {
  id         String       @id @default(uuid())
  user_id    String
  endpoint   String
  p256dh     String
  auth       String
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  user       UserSettings @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([user_id, endpoint])
  @@index([user_id])
}

model FcmToken {
  user_id    String
  token      String
  created_at DateTime     @default(now()) @db.Timestamptz(6)
  user       UserSettings @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@id([user_id, token])
  @@index([user_id])
}

model ForumBan {
  id           String         @id @default(uuid())
  user_id      String
  category_id  String?
  reason       String?
  banned_by    String
  expires_at   DateTime?      @db.Timestamptz(6)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  user         UserSettings   @relation("BannedUser", fields: [user_id], references: [user_id])
  category     ForumCategory? @relation(fields: [category_id], references: [id])
  banned_by_user UserSettings @relation("BannedByUser", fields: [banned_by], references: [user_id])

  @@index([user_id])
}
